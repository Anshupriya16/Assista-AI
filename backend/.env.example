PORT=5000
CLIENT_URL=http://localhost:5173
# For multiple deployed frontend domains, use comma-separated URLs.
# CLIENT_URLS=https://your-frontend.vercel.app,https://your-preview.vercel.app
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/assista-ai?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_secret

# Gemini is optional. If no key is configured, the backend uses local fallback replies.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash

# Turn this on temporarily to return AI provider errors during development.
AI_DEBUG=false
